# System-under-test endpoints
SYNAPSE_L4_BASE_URL=http://localhost:8000
SENTINEL_L7_MCP_URL=http://localhost:8080/mcp

# Ollama — LLM-as-judge (online/judge.py). Remote host over Tailscale in this
# dev environment; one instance also serves the embedding model below.
OLLAMA_JUDGE_HOST=http://100.82.223.70:11434
OLLAMA_JUDGE_MODEL=qwen3.5:9b-q4_K_M

# Ollama — embedding consistency layer (online/consistency.py). Same env var
# names as Sentinel-L7's own OLLAMA_URL/OLLAMA_EMBEDDING_MODEL — must match
# Sentinel-L7's real embedding config exactly or Upstash Vector will reject
# on a dimension mismatch (see docs/adr/0001-standalone-module.md).
OLLAMA_URL=http://100.82.223.70:11434
OLLAMA_EMBEDDING_MODEL=nomic-embed-text:v1.5

# Gemini Flash — judge fallback (online/judge.py). Same env var names as
# Sentinel-L7's config/services.php.
GEMINI_API_KEY=your-gemini-api-key
GEMINI_FLASH_URL=https://generativelanguage.googleapis.com/v1beta/models/gemini-2.0-flash:generateContent

# Upstash Vector — embedding consistency layer. Account-specific secrets,
# no safe default. Namespace is hardcoded to "transactions" in config.py to
# match TransactionProcessorService::NAMESPACE.
UPSTASH_VECTOR_REST_URL=https://your-index.upstash.io
UPSTASH_VECTOR_REST_TOKEN=your-upstash-token
UPSTASH_VECTOR_THRESHOLD=0.90

# OpenTelemetry — same Collector endpoint as Sentinel-L7/Synapse-L4/EventHorizon
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_SERVICE_NAME=arbiter-l8
